{
  "name": "japanese-shadowing-pwa",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:js": "babel src/app.jsx --presets @babel/preset-react -o dist/app.js",
    "build:css": "tailwindcss -i src/input.css -o dist/tailwind.css --minify",
    "build": "npm run build:css && npm run build:js",
    "serve": "python3 -m http.server 8080"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "tailwindcss": "^3.4.0"
  }
}
